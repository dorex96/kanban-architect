generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  INBOX
  TODO
  IN_PROGRESS
  DONE
}

model Project {
  id            String         @id @default(cuid())
  name          String
  createdAt     DateTime       @default(now())
  tasks         Task[]
  events        Event[]
  agentLogs     AgentLog[]
  chatMessages  ChatMessage[]
  notifications Notification[]
  weeklyChecks  WeeklyProjectCheckRun[]
}

enum WeeklyProjectCheckRunStatus {
  SUCCESS
  ERROR
  SKIP
}

enum WeeklyProjectCheckTriggerType {
  SCHEDULED
  MANUAL
}

model Task {
  id            String     @id @default(cuid())
  projectId     String
  title         String
  description   String     @default("")
  status        TaskStatus @default(INBOX)
  positionIndex Float      @default(0)
  priority      Int        @default(3)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime   @default(now())
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events        Event[]

  @@index([projectId])
}

model Event {
  id        String   @id @default(cuid())
  projectId String
  taskId    String?
  action    String
  timestamp DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model AgentLog {
  id        String   @id @default(cuid())
  projectId String
  query     String
  reasoning String   @default("")
  toolCalls Json     @default("[]")
  status    String   @default("success")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String
  role      String
  content   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Notification {
  id        String    @id @default(cuid())
  projectId String
  message   String
  isRead    Boolean   @default(false)
  reply     String?
  repliedAt DateTime?
  createdAt DateTime  @default(now())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model WeeklyProjectCheckRun {
  id           String                        @id @default(cuid())
  projectId    String
  triggerType  WeeklyProjectCheckTriggerType
  status       WeeklyProjectCheckRunStatus
  tasksAnalyzed Int                          @default(0)
  generatedText String?
  errorMessage  String?
  startedAt     DateTime
  finishedAt    DateTime
  createdAt     DateTime                     @default(now())
  project       Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}
